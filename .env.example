# Copy to .env and fill in. .env is git-ignored.

# Google AI Studio / Gemini API key. Leave blank to run in offline mode.
GEMINI_API_KEY=

# Set to "true" to force offline (hash) embeddings with no network calls.
OFFLINE_MODE=false

# Models (defaults are sensible; override only if needed).
EMBEDDING_MODEL=models/text-embedding-004
GENERATION_MODEL=models/gemini-2.0-flash
EMBEDDING_DIM=768

# Storage + retrieval tuning.
DATA_DIR=data
UPLOAD_DIR=data/uploads
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4

# Logging.
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
